{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bluesky Post Manager",
  "version": "0.1.0",
  "identifier": "com.example.bsky-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bluesky Post Manager",
        "width": 1100,
        "height": 780,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:1420 ws://localhost:1421 https://bsky.social https://*.bsky.network https://*.bsky.app; img-src 'self' asset: https://asset.localhost https://cdn.bsky.app https://*.bsky.app https://*.bsky.network; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
